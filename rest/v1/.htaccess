RewriteRule ^purchase-order/search$ controllers/developer/suppliers/purchase-order/search.php [L]

### STOCK MOVEMENT ### 
RewriteRule ^stock-movement$ controllers/developer/inventory/stock-movement/stock-movement.php [L]
RewriteRule ^stock-movement/([0-9]+)$ controllers/developer/inventory/stock-movement/stock-movement.php?id=$1 [L] 
RewriteRule ^stock-movement/active/([0-9]+)$ controllers/developer/inventory/stock-movement/active.php?id=$1 [L] 
