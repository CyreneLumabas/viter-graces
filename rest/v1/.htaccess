RewriteEngine On
# use for authentication
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f

Header set Access-Control-Allow-Origin *

#################################### ALL FOR DEVELOPER #################################
### FOR UPLOAD PHOTO ###
RewriteRule ^upload-multiple-files$ core/upload-multiple-files.php [L]  

### ROLES ###
RewriteRule ^roles$ controllers/developer/settings/role/role.php [L]
RewriteRule ^roles/([0-9]+)$ controllers/developer/settings/role/role.php?roleid=$1 [L]
RewriteRule ^roles/active/([0-9]+)$ controllers/developer/settings/role/active.php?roleid=$1 [L]
  