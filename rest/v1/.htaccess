### SALES ORDER ### 
RewriteRule ^sales-order$ controllers/developer/sales-order/sales-order.php [L]
RewriteRule ^sales-order/([0-9]+)$ controllers/developer/sales-order/sales-order.php?id=$1 [L] 
RewriteRule ^sales-order/active/([0-9]+)$ controllers/developer/sales-order/active.php?id=$1 [L] 
